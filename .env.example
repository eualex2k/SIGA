# Lovable Cloud configura essas variáveis automaticamente.
# Para rodar fora do Lovable, copie este arquivo para .env e preencha.

# Public (browser)
VITE_SUPABASE_URL="https://SEU-PROJETO.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sua-anon-key"
VITE_SUPABASE_PROJECT_ID="seu-project-id"

# Server (SSR / server functions)
SUPABASE_URL="https://SEU-PROJETO.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sua-anon-key"
SUPABASE_PROJECT_ID="seu-project-id"
# SUPABASE_SERVICE_ROLE_KEY é injetada apenas no ambiente de produção/edge — nunca a exponha.
